POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=rag_chunks

EMBEDDING_MODEL=docker.io/ai/embeddinggemma:latest
EMBEDDING_BASE_URL=http://host.docker.internal:12434/v1
EMBEDDING_API_KEY=dummy
EMBEDDING_MAX_INPUT_TOKENS=400

LLM_MODEL=docker.io/ai/qwen3:8B-Q4_K_M
LLM_BASE_URL=http://host.docker.internal:12434/v1
LLM_API_KEY=dummy

CHUNK_SIZE=600
CHUNK_OVERLAP=100
WATCH_INTERVAL=10

RETRIEVAL_SCORE_THRESHOLD=0.70
RETRIEVAL_MIN_RESULTS=2
RETRIEVAL_MAX_RESULTS=8

CHAT_HISTORY_LIMIT=5
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000
ENABLE_OCR=true
PDF_OCR_MODE=fallback
PDF_MIN_EXTRACTED_CHARS=500
PDF_MIN_AVG_CHARS_PER_PAGE=150
PDF_ENABLE_COLUMN_DETECTION=true
PDF_RENDER_SCALE=2.0
OCR_LANGUAGE=eng
OCR_ENABLE_PREPROCESSING=true
OCR_PREPROCESS_GRAYSCALE=true
OCR_PREPROCESS_THRESHOLD=true
OCR_PREPROCESS_DENOISE=false
OCR_PREPROCESS_CONTRAST=true
HTML_CLEANING_STRICT=true
EPUB_SKIP_FRONT_MATTER=true
EPUB_REMOVE_REPEATED_CHROME=true
EPUB_FALLBACK_SCAN_ENABLED=true
INDEX_SCHEMA_VERSION=2
PROCESSOR_VERSION=2
NORMALIZATION_VERSION=2
EXTRACTION_STRATEGY_VERSION=2
LOG_LEVEL=INFO
DATA_DIR=/app/data
